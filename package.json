    "@angular/platform-server": "22.0.0",
    "@angular/router": "22.0.0",
    "@angular/ssr": "22.0.0",
    "express": "^5.1.0",
    "rxjs": "~7.8.0",
    "tslib": "^2.3.0"
  },
  "devDependencies": {
    "@angular-devkit/core": "22.0.0",
