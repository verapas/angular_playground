{
  "$schema": "../../node_modules/nx/schemas/project-schema.json",
  "name": "angular_playground",
  "projectType": "application",
  "generators": {
    "@schematics/angular:component": {
      "style": "scss"
    }
  },
  "sourceRoot": "apps/angular-playground/src",
  "prefix": "app",
  "targets": {
    "build": {
      "executor": "@angular/build:application",
      "options": {
        "browser": "apps/angular-playground/src/main.ts",
        "tsConfig": "apps/angular-playground/tsconfig.app.json",
        "inlineStyleLanguage": "scss",
        "assets": [
          {
            "glob": "**/*",
            "input": "apps/angular-playground/public"
          }
        ],
        "styles": [
          "apps/angular-playground/src/styles.scss"
        ],
        "server": "apps/angular-playground/src/main.server.ts",
        "outputMode": "server",
        "ssr": {
          "entry": "apps/angular-playground/src/server.ts"
        },
        "outputPath": "dist/angular_playground"
      },
      "configurations": {
        "production": {
          "budgets": [
            {
              "type": "initial",
              "maximumWarning": "500kB",
              "maximumError": "1MB"
            },
            {
              "type": "anyComponentStyle",
              "maximumWarning": "4kB",
              "maximumError": "8kB"
            }
          ],
          "outputHashing": "all"
        },
        "development": {
          "optimization": false,
          "extractLicenses": false,
          "sourceMap": true
        }
      },
      "defaultConfiguration": "production",
      "outputs": [
        "{options.outputPath}"
      ]
    },
    "serve": {
      "executor": "@angular/build:dev-server",
      "configurations": {
        "production": {
          "buildTarget": "angular_playground:build:production"
        },
        "development": {
          "buildTarget": "angular_playground:build:development"
        }
      },
      "defaultConfiguration": "development"
    },
    "extract-i18n": {
      "executor": "@angular/build:extract-i18n"
    },
    "test": {
      "executor": "@angular/build:karma",
      "options": {
        "tsConfig": "apps/angular-playground/tsconfig.spec.json",
        "inlineStyleLanguage": "scss",
        "assets": [
          {
            "glob": "**/*",
            "input": "apps/angular-playground/public"
          }
        ],
        "styles": [
          "apps/angular-playground/src/styles.scss"
        ]
      }
    }
  }
}
